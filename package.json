{
  "name": "api-pilot",
  "displayName": "API Pilot",
  "description": "VS Code API client supporting HTTP, WebSocket, SSE, MQTT and gRPC — send requests, stream events, manage collections and history",
  "version": "1.5.0",
  "publisher": "dootn",
  "icon": "resources/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/dootn/api-pilot"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Testing",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "apiPilot.openPanel",
        "title": "Open API Pilot",
        "category": "API Pilot"
      }
    ],
    "configuration": {
      "title": "API Pilot",
      "properties": {
        "api-pilot.locale": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "en",
            "zh-CN"
          ],
          "enumDescriptions": [
            "Follow VS Code UI language",
            "English",
            "中文 (Chinese Simplified)"
          ],
          "description": "Display language for API Pilot UI. Requires webview reload to take effect."
        },
        "api-pilot.maxHistory": {
          "type": "number",
          "default": 1000,
          "minimum": 10,
          "maximum": 10000,
          "description": "Maximum total number of history entries to keep across all days. When the limit is reached, the oldest entries are removed automatically."
        },
        "api-pilot.requestTimeout": {
          "type": "number",
          "default": 30000,
          "minimum": 1000,
          "maximum": 300000,
          "description": "Global request timeout in milliseconds. Applies to both receiving response headers and downloading the response body. Default: 30000 (30 s)."
        },
        "api-pilot.customHttpMethods": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional HTTP methods to show in the method selector dropdown (e.g. [\"PROPFIND\", \"MKCOL\"])."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "npm run build:extension && npm run build:webview",
    "build:extension": "node esbuild.js --production",
    "build:webview": "cd webview-ui && npm run build",
    "watch": "node esbuild.js --watch",
    "dev:webview": "cd webview-ui && npm run dev",
    "lint": "eslint src --ext ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@types/ws": "^8.5.10",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0",
    "vitest": "^1.6.1"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0",
    "aedes": "^1.0.2",
    "mqtt": "^5.15.1",
    "undici": "^6.6.0",
    "ws": "^8.18.0"
  }
}
